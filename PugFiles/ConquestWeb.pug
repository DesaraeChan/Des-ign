doctype html
head
  meta(charset='utf-8')
  meta(name='viewport' content='width=device-width, initial-scale=1')
  title Conquest Enterprise - Desmond Chen
  link(rel='icon' type='image/x-icon' href='/css/img/icons/MainIcon.ico')
  link(rel='preconnect' href='https://fonts.googleapis.com')
  link(rel='preconnect' href='https://fonts.gstatic.com' crossorigin='')
  script(src='/JavaScript/dropdown.js' defer='')
  script(src='/JavaScript/fadeIn.js' defer='')
  link(href='/css/main.css' rel='stylesheet')
include inc/_navCase
main
  section
    a(href = "https://www.conquestent.ca/" target='_blank' rel='noopener noreferrer')
        img.caseImg(alt='Conquest Enterprises Frontpage' src='/css/img/ConquestImg/ConquestMain.png' height='600' weight='1000')
    .caseContainer
      div
        h1.caseTitle Conquest 
        h1.caseTitle Ent. Website
        p.projectCaseSubTitle Contract Work
        
      div
        p.descriptionSubhead Summary
        h2.descriptionHeader
          | Redesigning their website to better showcase their goals
          | &amp; expertise over their many years of operation
        hr
        .descriptionRoles
          div
            p.roleTitles Role
            p Visual Design, Web Implimentation
          div
            p.roleTitles Tools
            p
              | Webflow, 
              | Figma
          div
            p.roleTitles Duration
            p 7 weeks, Summer 2023
          div
            p.roleTitles Link
            a.websiteDirect(href = "https://www.conquestent.ca/" target='_blank' rel='noopener noreferrer') Check it out here
include inc/_footer